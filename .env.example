# ─── Application ───────────────────────────────────
APP_NAME=CortexDocs ∞
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cortexdocs:cortexdocs@localhost:5432/cortexdocs
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ─── Embedding Model ───────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# ─── Reranker Model ────────────────────────────────
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_TOP_K=10

# ─── Chunking ──────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Retrieval ─────────────────────────────────────
RETRIEVAL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
HYBRID_ALPHA=0.7
HYBRID_BETA=0.3

# ─── LLM ───────────────────────────────────────────
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_MAX_ATTEMPTS=3

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Cache ─────────────────────────────────────────
CACHE_ENABLED=true
CACHE_EMBEDDING_MAX_SIZE=1000
CACHE_ANSWER_MAX_SIZE=100
CACHE_ANSWER_TTL_SECONDS=300

# ─── Storage Paths ─────────────────────────────────
UPLOAD_DIR=./data/uploads
FAISS_INDEX_DIR=./data/faiss
BM25_INDEX_DIR=./data/bm25

# ─── Feature Flags (prefix: FF_) ──────────────────
FF_ENABLE_HYBRID_SEARCH=true
FF_ENABLE_RERANKING=true
FF_ENABLE_ADAPTIVE_RETRIEVAL=true
FF_ENABLE_CONTRADICTION_DETECTION=true
FF_ENABLE_INTENT_CLASSIFICATION=true
FF_ENABLE_CONFIDENCE_SCORING=true
FF_ENABLE_EMBEDDING_CACHE=true
FF_ENABLE_ANSWER_CACHE=true
FF_ENABLE_QUERY_LOGGING=true
FF_ENABLE_LATENCY_TRACKING=true
FF_ENABLE_MAGIC_BYTES_VALIDATION=true
FF_ENABLE_RATE_LIMITING=true
